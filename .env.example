# Copy this file to .env.local for local development
# Never commit .env.local — it is in .gitignore

# The Cloudflare Pages Function endpoint for form submission
VITE_FORM_ENDPOINT=/api/contact

# Web3Forms API key — used as fallback when VITE_FORM_ENDPOINT is not set
# Get your free key at https://web3forms.com
VITE_WEB3FORMS_KEY=your_web3forms_access_key_here
